{
  "name": "@luaskills/sdk",
  "version": "0.2.2",
  "description": "TypeScript and Node.js SDK for integrating the LuaSkills runtime through the JSON FFI surface.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "luaskills": "./dist/cli.js"
  },
  "files": [
    "dist",
    "examples",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "prepack": "npm run build"
  },
  "keywords": [
    "lua",
    "skills",
    "ffi",
    "runtime",
    "sdk"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LuaSkills/luaskills.git",
    "directory": "sdk/typescript"
  },
  "dependencies": {
    "koffi": "^2.14.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20"
  }
}
